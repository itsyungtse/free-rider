# Telegram bot token from @BotFather  (SECRET — never commit)
BOT_TOKEN=

# Your Telegram numeric user ID (allowlist). Leave blank on first run — the bot
# prints your ID when you message it; paste it here, then restart.
ALLOWED_USER_ID=

# Parent directory holding the projects Claude may work in. Use an ABSOLUTE
# path (no ~). Each chat picks a subdirectory with /cd; messages then run inside
# that project.
PROJECTS_ROOT=

# Permission mode: acceptEdits | bypassPermissions | default | plan
PERMISSION_MODE=acceptEdits
